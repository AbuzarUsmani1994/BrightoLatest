@model FOS.Shared.ComplaintData
@{
    ViewBag.Title = "Manage Complaints";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href='~/Content/Style/fullcalendar.min.css' rel='stylesheet' />
<link href='~/Content/Style/fullcalendar.print.min.css' rel='stylesheet' media='print' />
<script src='~/Scripts/lib/moment.min.js'></script>
<script src='~/Scripts/lib/jquery-ui.min.js'></script>
<script src='~/Scripts/lib/fullcalendar.min.js'></script>
<link href="~/Content/Style/jquery-ui.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/select2/3.5.4/select2.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/select2/3.5.4/select2.min.js"></script>

<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN THEME CUSTOMIZER-->
        <!-- END THEME CUSTOMIZER-->
        <!-- BEGIN PAGE TITLE & BREADCRUMB-->
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Complaint</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage Complaints</a>
            </li>
        </ul>
        <!-- END PAGE TITLE & BREADCRUMB-->
    </div>
</div>



<!-- BEGIN EDITABLE TABLE widget-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN EXAMPLE TABLE widget-->
        <div class="widget green">
            <div class="widget-title">
                <h4 style="text-align:center">Manage Complaints</h4>

            </div>

            <div class="container" style="margin-top:2px;">
                <div class="row">
                    <form class="form-inline">
                        <label class="control-label" style="display:inline;margin-left:40px">Starting Date *</label>
                        <input class="text-box single-line" id="StartingDate1" name="StartingDate1" autocomplete="off" style="height: 22px; width: 202px; margin-bottom: 0px;">
                        <label class="control-label" style="display:inline">Ending Date *</label>
                        <input class="text-box single-line" id="StartingDate2" name="StartingDate2" autocomplete="off" style="height: 22px; width: 202px; margin-bottom: 0px;">

                        <label class="control-label">Regional Head *</label>

                        @Html.DropDownListFor(model => model.RegionalHeadID, new SelectList(Model.RegionalHead, "ID", "Name"), new { @class = "" })
                        @Html.ValidationMessageFor(model => model.RegionalHeadID)

                        <button type="button" id="ApplyFilter" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right: 2px"></i><span style="width:50px">Apply Filter</span>
                        </button>

                    </form>
                </div>
            </div>
        </div>
        <!-- END EXAMPLE TABLE widget-->
    </div>
</div>
<!-- BEGIN EDITABLE TABLE widget-->
<div class="row-fluid">
    <div class="span12">
        <!-- BEGIN EXAMPLE TABLE widget-->
        <div class="widget green">
            <div class="widget-title">
                <h4 style="text-align:center">All Complaints</h4>
                <span class="tools">
                    @*<a href="javascript:;" class="icon-chevron-down"></a>*@
                    @*<a href="javascript:;" class="icon-remove"></a>*@
                </span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        @*<div class="btn-group">
                                <button id="editable-sample_new" class="btn green">
                                    Add New <i class="icon-plus"></i>
                                </button>
                            </div>*@
                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th style="width:5%">Sr #</th>
                                <th style="width:20%">
                                    Complaint Number
                                </th>
                                <th style="width:20%">
                                    Complaint Date
                                </th>
                                <th style="width:20%">
                                    Sale Officer
                                </th>
                                <th style="width:20%">
                                    Customer Name
                                </th>
                                <th style="width:5%">
                                    Dealer Name
                                </th>
                                <th style="width:5%">
                                    Updated At
                                </th>
                                <th style="width:15%">
                                    Is Verified
                                </th>
                                <th style="width:10%">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- END EXAMPLE TABLE widget-->
    </div>
</div>
<!-- END EDITABLE TABLE widget-->

<div id="ProductDetail" class="modal hide fade in" role="dialog" style="width: 69%;height: 90%;top: 4%;left: 18%;overflow-y:no-display;">

    <div class="modal-dialog">

        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">

                <div class="span12">
                    <button type="button" class="close" id="closetab" data-dismiss="modal">&times;</button>
                    <h2 style="margin-top: -10px;text-align:center;color: #62c462;font-weight: bolder;border-bottom: 1px solid #62c462;border-top: 1px solid #62c462;padding-bottom: 10px;padding-top: 10px;" id="jobstatus">Quality Review</h2>

                    <div class="span12" style="padding:5px">
                        <div class="row">
                            <form class="form-inline">
                                <span id="CompaintID" style="display:none"></span>
                                <div class="span3">
                                    <span>Complaint No:</span>
                                    <span id="complaintno"></span>
                                </div>
                                <div class="span3">
                                    <span>Submitted Date:</span>
                                    <span id="submitteddate"></span>
                                </div>
                                <div class="span3">
                                    <span>Submitted By:</span>
                                    <span id="submittedby"></span>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="span12" style="padding:5px">
                        <div class="container">
                            <form class="form-inline">
                                <div class="row">
                                    <div class="span3">
                                        <label class="control-label">Application Cause</label>
                                        @Html.DropDownListFor(model => model.AppID, new SelectList(Model.ApplicationCauses, "ID", "AppName"), new { @class = "", @multiple = "multiple" })
                                        @Html.ValidationMessageFor(model => model.AppID)
                                    </div>
                                    <div class="span3">
                                        <label class="control-label">Substrate Cause</label>
                                        @Html.DropDownListFor(model => model.SubsID, new SelectList(Model.SubstrateCauses, "ID", "SubName"), new { @class = "", @multiple = "multiple" })
                                        @Html.ValidationMessageFor(model => model.SubsID)
                                    </div>
                                    <div class="span3">
                                        <label class="control-label">Product Quality Related</label>
                                        @Html.DropDownListFor(model => model.QuaID, new SelectList(Model.ComplaintProducts, "ID", "QuaName"), new { @class = "", @multiple = "multiple" })
                                        @Html.ValidationMessageFor(model => model.QuaID)
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="span3" id="OtherApplication1">
                                        <label class="control-label">Application</label>
                                        @Html.TextBoxFor(model => model.OtherApplication)
                                    </div>
                                    <div class="span3" id="OtherSubstrate1">
                                        <label class="control-label">Substrate</label>
                                        @Html.TextBoxFor(model => model.OtherSubstrate)
                                    </div>
                                    <div class="span3" id="OtherQuality1">
                                        <label class="control-label">Quality Product</label>
                                        @Html.TextBoxFor(model => model.OtherQuality)
                                    </div>
                                </div>
                                <div class="row" style="margin-top:5px">
                                    <div class="span3">
                                        <label class="control-label">Remarks</label>
                                        @Html.TextAreaFor(x => x.Remarks)
                                    </div>
                                    <div class="span3" style="margin-top:30px">
                                        <select id="ComplaintYesNo" name="ComplaintYesNo">
                                            <option value="1">Justify</option>
                                            <option value="2">Not Justify</option>
                                            <option value="3">In Progress</option>
                                        </select>
                                        @*@Html.DropDownListFor(
                                                m => m.CourseId,
                                                new List<SelectListItem>
                                                {
                                                    new SelectListItem { Text = "Computer Science", Value = "1" },
                                                    new SelectListItem { Text = "Mathematics", Value = "2" },
                                                    new SelectListItem { Text = "Physics", Value = "3" }
                                                },
                                                "-- Select Course --",
                                                new { @class = "form-control" }
                                            )*@
                                    </div>
                                </div>
                                <div class="row" style="margin-top:5px">
                                    <div class="span3">
                                        <label class="control-label">Image</label>
                                        <input type="file" name="ImageUrl" id="ImageUrl" accept="image/*" value="" />
                                    </div>
                                    <div class="span3">
                                        <label class="control-label">Video</label>
                                        <input type="file" name="VideoUrl" id="VideoUrl" accept="video/*" value="" />
                                    </div>
                                </div>
                            </form>
                            <div class="row">
                                <span class="span3" style="margin-top:5px; margin-left:0px">
                                    <button id="PompSave" class="btn btn-primary">Save</button>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/Scripts/js/preview.js"></script>
<script>
    $(document).ready(function () {

        $('#StartingDate1').datepicker(
            {
                dateFormat: 'dd-M-yy',
                changeMonth: true,
                changeYear: true,
                yearRange: '1950:2100'
            });

        $('#StartingDate2').datepicker(
            {
                dateFormat: 'dd-M-yy',
                changeMonth: true,
                changeYear: true,
                yearRange: '1950:2100'
            });

        GenerateDetailGrid();
        $("#ProductDetail").modal('hide');

        $("#AppID").select2({
            width: "100%",
            placeholder: "Select",
            allowClear: true
        });
        $("#SubsID").select2({
            width: "100%",
            placeholder: "Select",
            allowClear: true
        });
        $("#QuaID").select2({
            width: "100%",
            placeholder: "Select",
            allowClear: true
        });

        $("#OtherApplication1").hide();
        $("#OtherSubstrate1").hide();
        $("#OtherQuality1").hide();


        //$("#AppID").change(function () {
        //    var appID = $("#AppID").val();
        //    var text = $(this).find(':selected').text();
        //    alertify.success(text);
        //});

        $("#AppID").on("select2-selecting", function (e) {
            var newValue = e.object.id;   // sirf new value
            if (newValue == "20") {
                $("#OtherApplication1").show();
            }
        });

        $("#AppID").on("select2-removing", function (e) {

            // safe way (v3 compatible)
            var removedValue = e.val || (e.object && e.object.id);

            if (removedValue == "20") {
                $("#OtherApplication1").hide();
                $("#OtherApplication").val(""); // optional clear
            }
        });

        $("#SubsID").on("select2-selecting", function (e) {
            var newValue = e.object.id;   // sirf new value
            if (newValue == "17") {
                $("#OtherSubstrate1").show();
            }
        });

        $("#SubsID").on("select2-removing", function (e) {

            // safe way (v3 compatible)
            var removedValue = e.val || (e.object && e.object.id);

            if (removedValue == "17") {
                $("#OtherSubstrate1").hide();
                $("#OtherSubstrate").val(""); // optional clear
            }
        });

        $("#QuaID").on("select2-selecting", function (e) {
            var newValue = e.object.id;   // sirf new value
            if (newValue == "28") {
                $("#OtherQuality1").show();
            }
        });

        $("#QuaID").on("select2-removing", function (e) {

            // safe way (v3 compatible)
            var removedValue = e.val || (e.object && e.object.id);

            if (removedValue == "28") {
                $("#OtherQuality1").hide();
                $("#OtherQuality").val(""); // optional clear
            }
        });

    });

    $("#closetab").click(function () {
        ClearFields();
    });

    $("#PompSave").click(function () {
        debugger
        var AppID = $("#AppID").val();
        var SubID = $("#SubsID").val();
        var QuaID = $("#QuaID").val();
        //var selectedValue = $('input[name="IsVerified"]:checked').val();
        var data = new FormData();
        var files = $("#ImageUrl").get(0).files;
        if (files.length > 0) {
            data.append("ImageUrl", files[0]);
        }

        var files1 = $("#VideoUrl").get(0).files;
        if (files1.length > 0) {
            data.append("VideoUrl", files1[0]);
        }

        data.append("ComplaintID", $("#CompaintID").text());
        data.append("SaleOfficerName", $("#submittedby").text());
        data.append("StartingDate1", $("#submitteddate").text());
        data.append("ComplaintNumber", $("#complaintno").text());
        data.append("AppID", $("#AppID").val());
        data.append("SubsID", $("#SubsID").val());
        data.append("QuaID", $("#QuaID").val());
        data.append("ComplaintYesNo", $("#ComplaintYesNo").val());
        data.append("Remarks", $("#Remarks").val());
        data.append("OtherApplication", $("#OtherApplication").val());
        data.append("OtherSubstrate", $("#OtherSubstrate").val());
        data.append("OtherQuality", $("#OtherQuality").val());

        if (AppID == "" || AppID == null) {
            alertify.error("Please Select Application Cause");
        }
        else if (SubID == "" || SubID == null) {
            alertify.error("Please Select Substrate Cause");
        }
        else if (QuaID == "" || QuaID == null) {
            alertify.error("Please Select Product Quality");
        }
        else {
            $.ajax({
            type: "Post",
            url: "@Url.Action("SaveManageComplaints", "Complaint")",
            cache: false,
            contentType: false,
            processData: false,
            data: data,
            success: function (res) {
                if (res == "1") {
                    alertify.success("Data Added Successfully");
                    $("#ProductDetail").modal('hide');
                    ClearFields();
                    var otable = $("#datatab").DataTable();
                    otable.ajax.reload();
                }
            }

        });
        }
    });

    function GenerateDetailGrid() {

        //$('#datatab tfoot th').each(function () {
        //    $(this).html('<input type="text" />');
        //});

        var oTable = $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "searching": false,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("ComplaintDataHandler", "Complaint")',
                "contentType": 'application/json; charset=utf-8',
                'data': function (data) {
                    //data.RegionalHeadType = $('#Type').val();
                    data.StartingDate1 = $("#StartingDate1").val();
                    data.StartingDate2 = $("#StartingDate2").val();
                    data.RegionalHeadID = $('#RegionalHeadID').val() == null ? 1 : $('#RegionalHeadID').val();
                    return data = JSON.stringify(data);
                },
            },
            "fnDrawCallback": function (osetting) {

                var UpdateCheck = "0";
                var DeleteCheck = "0";

                if (UpdateCheck == "@HttpContext.Current.Session["UpdateCheck"]") { $(".edit").css("display", "none"); }
                else {
                    $(".edit").on("click", function () {
                        var ComplaintID = $(this).attr("data-id");
                        var ComplaintNo = $(this).attr("data-complaintNo");
                        var SoName = $(this).attr("data-soname");
                        var created = $(this).attr("data-created");

                        $.ajax({
                            type: "Get",
                            url: "@Url.Action("GetSuggestData", "Complaint")",
                            data: { ComplaintID: ComplaintID },
                            success: function (res) {
                                debugger
                                if (res == null || res == "") {

                                    ClearFields();
                                    $("#CompaintID").text(ComplaintID);
                                    $("#complaintno").text(ComplaintNo);
                                    $("#submitteddate").text(created);
                                    $("#submittedby").text(SoName);
                                    //$("#IsVerified").val(res.IsVerified);
                                    //val = "True";
                                    //$('input[name="IsVerified"][value="' + val + '"]')
                                    //    .prop('checked', true);
                                }
                                else {
                                    $("#CompaintID").text(res.ComplaintID);
                                    $("#complaintno").text(res.ComplaintNumber);
                                    $("#submitteddate").text(res.StartingDate1);
                                    $("#submittedby").text(res.SaleOfficerName);
                                    var selected = res.AppID.split(",");
                                    $("#AppID").val(selected).trigger("change");
                                    for (var i = 0; i < selected.length; i++) {
                                        if (selected[i] == "20") {
                                            $("#OtherApplication1").show();
                                        }
                                    }
                                    var selectedsub = res.SubsID.split(",");
                                    $("#SubsID").val(selectedsub).trigger("change");
                                    for (var i = 0; i < selectedsub.length; i++) {
                                        if (selectedsub[i] == "17") {
                                            $("#OtherSubstrate1").show();
                                        }
                                    }
                                    var selectedQua = res.QuaID.split(",");
                                    $("#QuaID").val(selectedQua).trigger("change");
                                    for (var i = 0; i < selectedQua.length; i++) {
                                        if (selectedQua[i] == "28") {
                                            $("#OtherQuality1").show();
                                        }
                                    }
                                    $("#Remarks").val(res.Remarks);
                                    $("#ComplaintYesNo").val(res.ComplaintYesNo);
                                    //var val = res.IsVerified.toString();
                                    //val = val.charAt(0).toUpperCase() + val.slice(1);
                                    //$('input[name="IsVerified"][value="' + val + '"]')
                                    //    .prop('checked', true);
                                }
                            }
                        });

                        $("html, body").animate({
                            scrollTop: $(window).scrollTop() - $(window).height()
                        }, 400);
                        $("#ProductDetail").modal('show');
                    });
                    }

                if (UpdateCheck == "@HttpContext.Current.Session["DeleteCheck"]") { $(".delete").css("display", "none"); }
                else {
                    $(".delete").on("click", function () {

                        var ComplaintID = $(this).attr("data-id");
                        window.open("@Url.Action("DownloadPDFCompalintReport", "Complaint")" + "?DateTO=" + $("#StartingDate2").val() + " &FromTO=" + $("#StartingDate1").val() + " &ComplaintID=" + ComplaintID);
                    });
                }
            },
            "fnRowCallback": function (nRow, aData, iDisplayIndex) {
                $("td:first", nRow).html(iDisplayIndex + 1);
                return nRow;
            },
            "oLanguage": { "sSearch": "Search Complaints : " },
            "sDom": 'lftipr',
            "processing": true,
            "deferRender": true,
            "bSelect": true,
            "columnDefs": [
                { "width": "60px", "targets": 0 }, // ComplaintID
                { "width": "110px", "targets": 1 }, // StartingDate1
                { "width": "130px", "targets": 2 }, // SaleOfficerName
                { "width": "130px", "targets": 3 }, // CustomerName
                { "width": "130px", "targets": 4 }, // DealerName
                { "width": "120px", "targets": 5 }, // ProductCategory
                { "width": "160px", "targets": 6 }, // ProductDesc
                { "width": "120px", "targets": 7 }, // ProductBatchNo
                { "width": "70px", "targets": 8 }  // Action button
            ],
            "columns": [
                { "data": "ComplaintID"},
                { "data": "ComplaintNumber"},
                { "data": "StartingDate1" },
                { "data": "SaleOfficerName" },
                { "data": "CustomerName" },
                { "data": "DealerName"},
                { "data": "StartingDate2" },
                { "data": "IsVerifiedString"},
            {
                "sClass": "center-align-td",
                "mData": null,
                "bSortable": false,
                "mRender": function (data, type, row) {
                    return '<button class="btn btn-success edit" data-id=' + row.ComplaintID + ' data-complaintNo=' + '"' + row.ComplaintNumber + '"' + ' data-soname=' + '"' + row.SaleOfficerName + '"' + ' data-created=' + '"' + row.StartingDate1 + '"' + '>' + '<i class=icon-pencil></i>' + '</button>&nbsp; <button class="btn btn-primary delete" style="margin-top:5px" data-id=' + row.ComplaintID + '>Report</button>';
                }
            }
            ],
            "order": [1, "asc"]

        });
    }

    $("#ApplyFilter").click(function () {
        var otable = $("#datatab").DataTable();
        otable.ajax.reload();
    });

    function ClearFields() {
        $("#CompaintID").text('');
        $("#submittedby").text('');
        $("#submitteddate").text('');
        $("#complaintno").text('');
        $("#AppID").val([]).trigger("change");
        $("#SubsID").val([]).trigger("change");
        $("#QuaID").val([]).trigger("change");
        $("#Remarks").val('');
        $("#OtherApplication").val('');
        $("#OtherSubstrate").val('');
        $("#OtherQuality").val('');
        $("#OtherApplication1").hide();
        $("#OtherSubstrate1").hide();
        $("#OtherQuality1").hide();
        $("#ComplaintYesNo").val('1');
        //val = "True";
        //$('input[name="IsVerified"][value="' + val + '"]')
        //    .prop('checked', true);
    }

</script>