@model FOS.Web.UI.Controllers.SetupController.QuarterData
@{
    ViewBag.Title = "Quarter Setup";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Setup</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage Quarters</a>
            </li>
        </ul>
    </div>
</div>

@using (Ajax.BeginForm("AddUpdateQuarter", "Setup", new AjaxOptions { OnSuccess = "OnSuccess", OnFailure = "OnFailure" }, new { @class = "form-horizontal" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.ID)

    <div class="row-fluid">
        <div class="span12">
            <div class="widget green">
                <div class="widget-title">
                    <h4>Manage Quarters</h4>
                    <span class="tools"></span>
                </div>
                <div class="widget-body">

                    <div class="control-group">
                        <label class="control-label">Financial Year *</label>
                        <div class="controls">
                            @Html.DropDownListFor(model => model.FinancialYearID,
                                new SelectList(Model.FinancialYears ?? new List<FOS.Shared.FinancialYearListItem>(), "ID", "Year"),
                                "-- Select Financial Year --",
                                new { @id = "FinancialYearID" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">Quarter Name *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.Name, new { @id = "Name", @placeholder = "e.g. Q1", @maxlength = "100" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">Start Date *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.StartDate, "{0:yyyy-MM-dd}", new { @id = "StartDate", @type = "date" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">End Date *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.EndDate, "{0:yyyy-MM-dd}", new { @id = "EndDate", @type = "date" })
                        </div>
                    </div>

                    <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                        <div class="form-actions" style="padding-left: 240px;">
                            <button type="submit" class="btn btn-primary">
                                <i class="icon-ok icon-white" style="padding-right: 8px;"></i><span id="btnLabel">Create</span>
                            </button>
                            <button type="button" class="btn btn-info" id="btnRefresh">
                                <i class="icon-ban-circle icon-white" style="padding-right: 8px;"></i>Reset
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>View Detail</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="control-group">
                        <label class="control-label" style="width:auto;padding-right:10px;">Filter by Financial Year:</label>
                        <div class="controls" style="display:inline-block;">
                            <select id="filterFY" style="min-width:180px;">
                                <option value="0">-- All --</option>
                                @foreach (var fy in (Model.FinancialYears ?? new List<FOS.Shared.FinancialYearListItem>()))
                                {
                                    <option value="@fy.ID">@fy.Year</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th style="width: 6% !important">Sr #</th>
                                <th>Financial Year</th>
                                <th>Quarter Name</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function fmtDate(val) {
        if (!val) return '';
        var m = /\/Date\((\d+)\)\//.exec(val);
        if (!m) return val;
        var d = new Date(parseInt(m[1]));
        return ('0' + d.getDate()).slice(-2) + '-' + ('0' + (d.getMonth() + 1)).slice(-2) + '-' + d.getFullYear();
    }

    function fmtDateInput(val) {
        if (!val) return '';
        var m = /\/Date\((\d+)\)\//.exec(val);
        if (m) {
            var d = new Date(parseInt(m[1]));
            return d.getFullYear() + '-' + ('0' + (d.getMonth() + 1)).slice(-2) + '-' + ('0' + d.getDate()).slice(-2);
        }
        if (/^\d{4}-\d{2}-\d{2}/.test(val)) return val.substring(0, 10);
        return val;
    }

    function GenerateDetailGrid() {
        if ($.fn.DataTable.isDataTable('#datatab')) {
            $('#datatab').DataTable().destroy();
            $('#datatab tbody').empty();
        }
        $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("QuarterDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                "dataType": "json",
                "data": function (d) {
                    d.FinancialYearID = $('#filterFY').val() || 0;
                    return JSON.stringify(d);
                }
            },
            "columns": [
                { "data": "ID", "bVisible": false },
                {
                    "data": null, "bSortable": false,
                    "render": function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "FinancialYearName" },
                { "data": "Name" },
                { "data": "StartDate", "render": function (data) { return fmtDate(data); } },
                { "data": "EndDate", "render": function (data) { return fmtDate(data); } },
                {
                    "data": null, "bSortable": false,
                    "render": function (data, type, row) {
                        return '<button class="btn btn-xs btn-warning" onclick="editQuarter(' + row.ID + ',\'' + (row.Name || '').replace(/'/g, "\\'") + '\',' + row.FinancialYearID + ',\'' + fmtDateInput(row.StartDate) + '\',\'' + fmtDateInput(row.EndDate) + '\')"><i class="icon-pencil"></i> Edit</button> ' +
                               '<button class="btn btn-xs btn-danger" onclick="deleteQuarter(' + row.ID + ')"><i class="icon-trash"></i> Delete</button>';
                    }
                }
            ],
            "language": {
                "sSearch": "Search: ",
                "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw"></i> Loading...',
                "emptyTable": "No data available",
                "zeroRecords": "No matching records found"
            },
            "sDom": 'lftipr',
            "order": [[1, "asc"]]
        });
    }

    function editQuarter(id, name, fyid, startDate, endDate) {
        $('#ID').val(id);
        $('#Name').val(name);
        $('#FinancialYearID').val(fyid);
        $('#StartDate').val(startDate);
        $('#EndDate').val(endDate);
        $('#btnLabel').text('Update');
        $('html, body').animate({ scrollTop: 0 }, 400);
        $('#Name').focus();
    }

    function deleteQuarter(id) {
        if (!confirm('Are you sure you want to delete this quarter?')) return;
        $.post('@Url.Action("DeleteQuarterRecord", "Setup")', { id: id }, function (res) {
            if (res.success) {
                alertify.success('Quarter deleted successfully');
                $('#datatab').DataTable().ajax.reload();
            } else {
                alertify.error(res.message || 'Delete failed');
            }
        });
    }

    function ClearForm() {
        $('#ID').val(0);
        $('#FinancialYearID').val('');
        $('#Name').val('');
        $('#StartDate').val('');
        $('#EndDate').val('');
        $('#btnLabel').text('Create');
    }

    function OnSuccess(response) {
        if (response == "1") {
            alertify.success("Quarter Saved Successfully");
            ClearForm();
            $('#datatab').DataTable().ajax.reload();
        } else if (response == "0") {
            alertify.error("Unable to save. Please fill all required fields.");
        } else {
            alertify.error(response);
        }
    }

    function OnFailure(response) {
        alertify.error("Request Failed");
    }

    $(document).ready(function () {
        $("#liSetup,#liQuarterSetup").addClass("active");

        $("#btnRefresh").click(function () {
            ClearForm();
        });

        $("#filterFY").change(function () {
            GenerateDetailGrid();
        });

        GenerateDetailGrid();
    });
</script>
