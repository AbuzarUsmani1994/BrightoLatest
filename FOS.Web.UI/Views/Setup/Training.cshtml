@model FOS.Shared.AreaData
@{
    ViewBag.Title = "Training";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Setup</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage Training</a>
            </li>
        </ul>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green" style="">
            <div class="widget-title">
                <h4>Manage Training</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">

                <div class="control-group">
                    <label class="control-label">Financial Year *</label>
                    <div class="controls">
                        @Html.DropDownListFor(model => model.FinancialYearID,
                            new SelectList(Model.FinancialYears ?? new List<FOS.Shared.FinancialYearListItem>(), "ID", "Year"),
                            "-- Select Financial Year --",
                            new { @id = "FinancialYearID" })
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Quarter *</label>
                    <div class="controls">
                        @Html.DropDownListFor(model => model.Quarter,
                            new SelectList(new[] { "Q1", "Q2", "Q3", "Q4" }),
                            "-- Select Quarter --",
                            new { @id = "Quarter" })
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Select Head *</label>
                    <div class="controls">
                        @Html.DropDownListFor(model => model.RegionID,
                            new SelectList(Model.RegionalHead ?? new List<FOS.Shared.RegionalHeadData>(), "ID", "Name"),
                            "-- Select Regional Head --",
                            new { @id = "RegionID" })
                    </div>
                </div>

                <div class="control-group">
                    <div class="controls" style="margin-left:0">
                        <table class="table table-striped table-hover table-bordered" id="trainingRowsTable" style="width:100%;">
                            <thead>
                                <tr>
                                    <th style="width:50%">SO Name</th>
                                    <th>Training Value</th>
                                </tr>
                            </thead>
                            <tbody id="trainingRowsBody">
                                <tr><td colspan="2" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>
                            </tbody>
                            <tfoot>
                                <tr style="font-weight:bold;background:#f5f5f5">
                                    <td style="text-align:right">Total:</td>
                                    <td id="totValue">0</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                    <div class="form-actions" style="padding-left:238px">
                        <button type="button" id="btnSaveAll" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right:8px"></i>Save All
                        </button>
                        <button type="button" id="btnRefresh" class="btn btn-info"><i class="icon-ban-circle icon-white" style="padding-right:8px"></i>Reset</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>View Detail</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="clearfix"><div class="btn-group pull-right"></div></div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th style="width: 6% !important">Sr #</th>
                                <th>Financial Year</th>
                                <th>Quarter</th>
                                <th>Head Name</th>
                                <th>SO Name</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function LoadSORows() {
        var rhID = $('#RegionID').val();
        var $body = $('#trainingRowsBody');
        $body.empty();

        if (!rhID || rhID == "") {
            $body.html('<tr><td colspan="2" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>');
            RecalcTotals();
            return;
        }

        $.ajax({
            url: '@Url.Action("GetSOByRegionalHeadID", "Setup")',
            type: 'GET',
            data: { RegionalHeadID: rhID },
            success: function (sos) {
                sos = sos || [];
                if (sos.length == 0) {
                    $body.html('<tr><td colspan="2" style="text-align:center;color:#888">No active SOs under selected head</td></tr>');
                    RecalcTotals();
                    return;
                }

                $.each(sos, function (i, s) {
                    var $row = $(
                        '<tr>' +
                            '<td>' + s.Name + '<input type="hidden" class="t-so" value="' + s.ID + '" /></td>' +
                            '<td><input type="number" min="0" step="any" class="t-value" style="width:100%" value="0" /></td>' +
                        '</tr>'
                    );
                    $body.append($row);
                });
                RecalcTotals();
            },
            error: function () {
                $body.html('<tr><td colspan="2" style="text-align:center;color:#c00">Failed to load SOs</td></tr>');
            }
        });
    }

    function RecalcTotals() {
        var t = 0;
        $('#trainingRowsBody .t-value').each(function () { t += parseFloat($(this).val()) || 0; });
        $('#totValue').text(t);
    }

    function CollectRows() {
        var rows = [];
        $('#trainingRowsBody tr').each(function () {
            var soInp = $(this).find('.t-so');
            if (soInp.length == 0) return;
            rows.push({
                SOID: parseInt(soInp.val()) || 0,
                Value: parseFloat($(this).find('.t-value').val()) || 0
            });
        });
        return rows;
    }

    function SaveAll() {
        var fy = $('#FinancialYearID').val();
        var q = $('#Quarter').val();
        var rh = $('#RegionID').val();
        if (!fy) { alertify.error("Please select Financial Year"); return; }
        if (!q) { alertify.error("Please select Quarter"); return; }
        if (!rh) { alertify.error("Please select Regional Head"); return; }

        var rows = CollectRows();
        if (rows.length == 0) { alertify.error("No SO rows to save"); return; }

        var payload = {
            FinancialYearID: parseInt(fy),
            Quarter: q,
            RegionID: parseInt(rh),
            TrainingRows: rows
        };

        $.ajax({
            url: '@Url.Action("SaveTrainingBulk", "Setup")',
            type: 'POST',
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify(payload),
            success: function (response) { OnSuccess(response); },
            error: function (resp) { OnFailure(resp); }
        });
    }

    function GenerateDetailGrid() {
        if ($.fn.DataTable.isDataTable('#datatab')) {
            $('#datatab').DataTable().destroy();
            $('#datatab tbody').empty();
        }

        $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("AddTrainingDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                "dataType": "json",
                "data": function (d) {
                    d.RegionalHeadID = $('#RegionID').val() || 0;
                    d.FinancialYearID = $('#FinancialYearID').val() || 0;
                    d.Quarter = $('#Quarter').val() || '';
                    return JSON.stringify(d);
                }
            },
            "columns": [
                { "data": "ID", "bVisible": false },
                {
                    "data": null,
                    "bSortable": false,
                    "render": function(data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                { "data": "FinancialYearName" },
                { "data": "Quarter" },
                { "data": "RegionName" },
                { "data": "CityName" },
                { "data": "Name" }
            ],
            "language": {
                "sSearch": "Search: ",
                "processing": '<i class="fa fa-spinner fa-spin fa-3x fa-fw"></i> Loading...',
                "emptyTable": "No data available",
                "zeroRecords": "No matching records found"
            },
            "sDom": 'lftipr',
            "order": [[1, "asc"]]
        });
    }

    $(document).ready(function () {
        $("#liSetup,#liTraining").addClass("active");

        $("#FinancialYearID, #Quarter").change(function () {
            GenerateDetailGrid();
        });

        $("#RegionID").change(function () {
            GenerateDetailGrid();
            LoadSORows();
        });

        $(document).on('input change', '#trainingRowsBody input', function () {
            RecalcTotals();
        });

        $("#btnRefresh").click(function () {
            ClearForm();
        });

        $("#btnSaveAll").click(function () {
            SaveAll();
        });

        GenerateDetailGrid();
    });

    function ClearForm() {
        $('#FinancialYearID').val('');
        $('#Quarter').val('');
        $('#RegionID').val('');
        $('#trainingRowsBody').html('<tr><td colspan="2" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>');
        RecalcTotals();
    }

    function OnSuccess(response) {
        if (response == "1") {
            alertify.success("Training Saved Successfully For All Active SOs");
            $('#datatab').DataTable().ajax.reload();
            ClearForm();
        }
        else if (response == "0") {
            alertify.error("Unable To Save. No active SO under the selected head, or invalid input.");
        }
        else {
            alertify.error(response);
        }
    }

    function OnFailure(response) {
        if (response.status == 422) {
            var errors = JSON.parse(response.responseText);
            alertify.error(errors.errors);
        }
        else {
            alertify.error(response);
        }
    }
</script>
