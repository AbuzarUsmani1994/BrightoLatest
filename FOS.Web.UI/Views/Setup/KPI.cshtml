@model FOS.Shared.CityData
@{
    ViewBag.Title = "KPI";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Setup</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage KPIS</a>
            </li>
        </ul>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green" style="">
            <div class="widget-title">
                <h4>Manage KPIS</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">

                <div class="control-group">
                    <label class="control-label">Financial Year *</label>
                    <div class="controls">
                        @Html.DropDownListFor(model => model.FinancialYearID,
                            new SelectList(Model.FinancialYears ?? new List<FOS.Shared.FinancialYearListItem>(), "ID", "Year"),
                            "-- Select Financial Year --",
                            new { @id = "FinancialYearID" })
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Regional Head *</label>
                    <div class="controls">
                        @Html.DropDownListFor(model => model.RegionalHeadID,
                            new SelectList(Model.RegionalHeads ?? new List<FOS.Shared.RegionalHeadData>(), "ID", "Name"),
                            "-- Select Regional Head --",
                            new { @id = "RegionalHeadID" })
                    </div>
                </div>

                <div class="control-group">
                    <div class="controls" style="margin-left:0">
                        <table class="table table-striped table-hover table-bordered" id="kpiRowsTable" style="width:100%;">
                            <thead>
                                <tr>
                                    <th style="width:30%">SO Name</th>
                                    <th>Platinum</th>
                                    <th>Premium</th>
                                    <th>Gold</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody id="kpiRowsBody">
                                <tr><td colspan="5" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>
                            </tbody>
                            <tfoot>
                                <tr style="font-weight:bold;background:#f5f5f5">
                                    <td style="text-align:right">Totals:</td>
                                    <td id="totPlatinum">0</td>
                                    <td id="totPremium">0</td>
                                    <td id="totGold">0</td>
                                    <td id="totTotal">0</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                    <div class="form-actions" style="padding-left: 238px;">
                        <button type="button" id="btnSaveAll" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right:8px"></i>Save All
                        </button>
                        <button type="button" id="btnRefresh" class="btn btn-info"><i class="icon-ban-circle icon-white" style="padding-right:8px"></i>Reset</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>View Detail</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th style="width: 6% !important">Sr #</th>
                                <th>Financial Year</th>
                                <th>Regional Head</th>
                                <th>Sale Officer</th>
                                <th>Platinum</th>
                                <th>Premium</th>
                                <th>Gold</th>
                                <th>Creation Date</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    var currentSOs = [];

    function LoadSORows() {
        var rhID = $('#RegionalHeadID').val();
        var $body = $('#kpiRowsBody');
        $body.empty();
        currentSOs = [];

        if (!rhID || rhID == "") {
            $body.html('<tr><td colspan="5" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>');
            RecalcTotals();
            return;
        }

        $.ajax({
            url: '@Url.Action("GetSOByRegionalHeadID", "Setup")',
            type: 'GET',
            data: { RegionalHeadID: rhID },
            success: function (sos) {
                currentSOs = sos || [];
                if (currentSOs.length == 0) {
                    $body.html('<tr><td colspan="5" style="text-align:center;color:#888">No active SOs under selected head</td></tr>');
                    RecalcTotals();
                    return;
                }

                var soOptions = '';
                $.each(currentSOs, function (i, s) {
                    soOptions += '<option value="' + s.ID + '">' + s.Name + '</option>';
                });

                $.each(currentSOs, function (i, s) {
                    var $row = $(
                        '<tr>' +
                            '<td><select class="kpi-so" data-row="' + i + '">' + soOptions + '</select></td>' +
                            '<td><input type="number" min="0" class="kpi-platinum" data-row="' + i + '" style="width:100%" value="0" /></td>' +
                            '<td><input type="number" min="0" class="kpi-premium" data-row="' + i + '" style="width:100%" value="0" /></td>' +
                            '<td><input type="number" min="0" class="kpi-gold" data-row="' + i + '" style="width:100%" value="0" /></td>' +
                            '<td><input type="number" min="0" class="kpi-total" data-row="' + i + '" style="width:100%" value="0" /></td>' +
                        '</tr>'
                    );
                    $row.find('select.kpi-so').val(s.ID);
                    $body.append($row);
                });

                RecalcTotals();
            },
            error: function () {
                $body.html('<tr><td colspan="5" style="text-align:center;color:#c00">Failed to load SOs</td></tr>');
            }
        });
    }

    function RecalcTotals() {
        var p = 0, pr = 0, g = 0, t = 0;
        $('#kpiRowsBody .kpi-platinum').each(function () { p += parseInt($(this).val()) || 0; });
        $('#kpiRowsBody .kpi-premium').each(function () { pr += parseInt($(this).val()) || 0; });
        $('#kpiRowsBody .kpi-gold').each(function () { g += parseInt($(this).val()) || 0; });
        $('#kpiRowsBody .kpi-total').each(function () { t += parseInt($(this).val()) || 0; });
        $('#totPlatinum').text(p);
        $('#totPremium').text(pr);
        $('#totGold').text(g);
        $('#totTotal').text(t);
    }

    function CollectRows() {
        var rows = [];
        $('#kpiRowsBody tr').each(function () {
            var soSel = $(this).find('select.kpi-so');
            if (soSel.length == 0) return;
            rows.push({
                SOID: parseInt(soSel.val()) || 0,
                Platinum: parseInt($(this).find('.kpi-platinum').val()) || 0,
                Premium: parseInt($(this).find('.kpi-premium').val()) || 0,
                Gold: parseInt($(this).find('.kpi-gold').val()) || 0,
                Total: parseInt($(this).find('.kpi-total').val()) || 0
            });
        });
        return rows;
    }

    function SaveAll() {
        var fy = $('#FinancialYearID').val();
        var rh = $('#RegionalHeadID').val();
        if (!fy) { alertify.error("Please select Financial Year"); return; }
        if (!rh) { alertify.error("Please select Regional Head"); return; }

        var rows = CollectRows();
        if (rows.length == 0) { alertify.error("No SO rows to save"); return; }

        var payload = {
            FinancialYearID: parseInt(fy),
            RegionalHeadID: parseInt(rh),
            KpiRows: rows
        };

        $.ajax({
            url: '@Url.Action("SaveKPISBulk", "Setup")',
            type: 'POST',
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify(payload),
            success: function (response) {
                OnSuccess(response);
            },
            error: function (resp) {
                OnFailure(resp);
            }
        });
    }

    function GenerateDetailGrid() {
        var oTable = $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("KPIDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                'data': function (data) {
                    data.SOID = 0;
                    data.FinancialYearID = $('#FinancialYearID').val() || 0;
                    data.RegionalHeadID = $('#RegionalHeadID').val() || 0;
                    return data = JSON.stringify(data);
                }
            },
            "fnRowCallback": function (nRow, aData, iDisplayIndex) {
                $("td:first", nRow).html(iDisplayIndex + 1);
                return nRow;
            },
            "oLanguage": { "sSearch": "Search KPI : " },
            "sDom": 'lftipr',
            "processing": true,
            "deferRender": true,
            "bSelect": true,
            "columns": [
                { "data": "ID", "bVisible": false },
                { "data": "ID", "bSortable": false },
                { "data": "FinancialYearName" },
                { "data": "RegionalHeadName" },
                { "data": "SOName" },
                { "data": "CoatingTarget" },
                { "data": "ACTDTarget" },
                { "data": "ReadyMixTarget" },
                {
                    "data": "LastUpdate",
                    "mRender": function (data) {
                        if (!data) return "";
                        var d = new Date(parseInt(data.replace(/\D/g, '')));
                        if (isNaN(d.getTime())) return data;
                        var dd = ('0' + d.getDate()).slice(-2);
                        var mm = ('0' + (d.getMonth() + 1)).slice(-2);
                        return dd + '-' + mm + '-' + d.getFullYear();
                    }
                },
                { "data": "TotalTarget" }
            ],
            "order": [1, "asc"]
        });
    }

    $(document).ready(function () {
        $("#liSetup,#liKPI").addClass("active");

        $("#FinancialYearID").change(function () {
            $('#datatab').dataTable().fnDestroy();
            GenerateDetailGrid();
        });

        $("#RegionalHeadID").change(function () {
            $('#datatab').dataTable().fnDestroy();
            GenerateDetailGrid();
            LoadSORows();
        });

        $(document).on('input change', '#kpiRowsBody input', function () {
            RecalcTotals();
        });

        $("#btnRefresh").click(function () {
            ClearForm();
        });

        $("#btnSaveAll").click(function () {
            SaveAll();
        });

        GenerateDetailGrid();
    });

    function ClearForm() {
        $('#FinancialYearID').val('');
        $('#RegionalHeadID').val('');
        $('#kpiRowsBody').html('<tr><td colspan="5" style="text-align:center;color:#888">Select a Regional Head to load SOs</td></tr>');
        RecalcTotals();
    }

    function OnSuccess(response) {
        if (response == "1") {
            alertify.success("KPI Saved Successfully For All SOs.");
            $('#datatab').DataTable().ajax.reload();
            ClearForm();
        }
        else if (response == "0") {
            alertify.error("Unable To Save KPIs.");
        }
        else if (response == "2") {
            alertify.error("Record Already Exists For Selected Regional Head & Financial Year");
        }
        else {
            alertify.error(response);
        }
    }

    function OnFailure(response) {
        if (response.status == 422) {
            var errors = JSON.parse(response.responseText);
            alertify.error(errors.errors);
        }
        else {
            alertify.error(response);
        }
    }
</script>
