@model FOS.Shared.CityData
@{
    ViewBag.Title = "KPI";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Setup</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage KPIS</a>
            </li>
        </ul>
    </div>
</div>

@using (Ajax.BeginForm("AddUpdateKPIS", "Setup", new AjaxOptions { OnSuccess = "OnSuccess", OnFailure = "OnFailure" }, new { @class = "form-horizontal" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)

    <div class="row-fluid">
        <div class="span12">
            <div class="widget green" style="">
                <div class="widget-title">
                    <h4>Manage KPIS</h4>
                    <span class="tools"></span>
                </div>
                <div class="widget-body">

                    <div class="control-group">
                        <label class="control-label">Financial Year *</label>
                        <div class="controls">
                            @Html.DropDownListFor(model => model.FinancialYearID,
                                new SelectList(Model.FinancialYears ?? new List<FOS.Shared.FinancialYearListItem>(), "ID", "Year"),
                                "-- Select Financial Year --",
                                new { @id = "FinancialYearID" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">Regional Head *</label>
                        <div class="controls">
                            @Html.DropDownListFor(model => model.RegionalHeadID,
                                new SelectList(Model.RegionalHeads ?? new List<FOS.Shared.RegionalHeadData>(), "ID", "Name"),
                                "-- Select Regional Head --",
                                new { @id = "RegionalHeadID" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">Sale Officer *</label>
                        <div class="controls">
                            @Html.DropDownListFor(model => model.SOID,
                                new SelectList(Model.SaleOfficers ?? new List<FOS.DataLayer.SaleOfficer>(), "ID", "Name"),
                                "-- Select Sale Officer --",
                                new { @id = "SOID" })
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label">Target For Ready Mix *</label>
                        <div class="controls">
                            @Html.EditorFor(model => model.ReadyMixTarget)
                            @Html.HiddenFor(model => model.ID)
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label" for="ACTDTarget">Target For ACTD *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.ACTDTarget)
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label" for="CoatingTarget">Target For Coatings *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.CoatingTarget)
                        </div>
                    </div>

                    <div class="control-group">
                        <label class="control-label" for="TotalTarget">Total Target *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.TotalTarget)
                        </div>
                    </div>

                    <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                        <div class="form-actions" style="padding-left: 238px;">
                            <button type="submit" id="btnNew" class="btn btn-primary">
                                <i class="icon-ok icon-white" style="padding-right:8px"></i><span id="create">Create</span>
                            </button>
                            <button type="button" id="btnRefresh" class="btn btn-info"><i class="icon-ban-circle icon-white" style="padding-right:8px"></i>Reset</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>View Detail</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th style="width: 6% !important">Sr #</th>
                                <th>Financial Year</th>
                                <th>Regional Head</th>
                                <th>Sale Officer</th>
                                <th>Target For Ready Mix</th>
                                <th>Target For ACTD</th>
                                <th>Target For Coatings</th>
                                <th>Creation Date</th>
                                <th>Total Target</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

    function GenerateDetailGrid() {
        var oTable = $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("KPIDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                'data': function (data) {
                    data.SOID = $('#SOID').val() || 0;
                    data.FinancialYearID = $('#FinancialYearID').val() || 0;
                    data.RegionalHeadID = $('#RegionalHeadID').val() || 0;
                    return data = JSON.stringify(data);
                }
            },
            "fnDrawCallback": function (osetting) {
            },
            "fnRowCallback": function (nRow, aData, iDisplayIndex) {
                $("td:first", nRow).html(iDisplayIndex + 1);
                return nRow;
            },
            "oLanguage": { "sSearch": "Search KPI : " },
            "sDom": 'lftipr',
            "processing": true,
            "deferRender": true,
            "bSelect": true,
            "columns": [
                { "data": "ID", "bVisible": false },
                { "data": "ID", "bSortable": false },
                { "data": "FinancialYearName" },
                { "data": "RegionalHeadName" },
                { "data": "SOName" },
                { "data": "ReadyMixTarget" },
                { "data": "ACTDTarget" },
                { "data": "CoatingTarget" },
                {
                    "data": "LastUpdate",
                    "mRender": function (data) {
                        if (!data) return "";
                        var d = new Date(parseInt(data.replace(/\D/g, '')));
                        if (isNaN(d.getTime())) return data;
                        var dd = ('0' + d.getDate()).slice(-2);
                        var mm = ('0' + (d.getMonth() + 1)).slice(-2);
                        return dd + '-' + mm + '-' + d.getFullYear();
                    }
                },
                { "data": "TotalTarget" }
            ],
            "order": [1, "asc"]
        });
    }

    function LoadSOByRegionalHead(rhId, selectedSO) {
        var $so = $('#SOID');
        $so.empty().append('<option value="">-- Select Sale Officer --</option>');
        if (!rhId) {
            $('#datatab').dataTable().fnDestroy();
            GenerateDetailGrid();
            return;
        }
        $.ajax({
            type: "POST",
            url: "@Url.Action("GetSOByRegionalHeadID", "Setup")",
            data: { RegionalHeadID: rhId },
            success: function (data) {
                if (data && data.length) {
                    $.each(data, function (i, item) {
                        $so.append('<option value="' + item.ID + '">' + item.Name + '</option>');
                    });
                }
                if (selectedSO) {
                    $so.val(selectedSO);
                }
                $('#datatab').dataTable().fnDestroy();
                GenerateDetailGrid();
            }
        });
    }

    $(document).ready(function () {
        $("#liSetup,#liKPI").addClass("active");

        $("#FinancialYearID").change(function () {
            $('#datatab').dataTable().fnDestroy();
            GenerateDetailGrid();
        });

        $("#RegionalHeadID").change(function () {
            LoadSOByRegionalHead($(this).val(), null);
        });

        $("#SOID").change(function () {
            $('#datatab').dataTable().fnDestroy();
            GenerateDetailGrid();
        });

        $("#btnRefresh").click(function () {
            ClearForm();
        });

        GenerateDetailGrid();
    });

    function ClearForm() {
        $('#FinancialYearID').val('');
        $('#RegionalHeadID').val('');
        $('#SOID').empty().append('<option value="">-- Select Sale Officer --</option>');
        $('#ReadyMixTarget').val('');
        $('#ACTDTarget').val('');
        $('#CoatingTarget').val('');
        $('#TotalTarget').val('');
        $('#ID').val(0);
        $('#create').text('Create');
    }

    function OnSuccess(response) {
        if (response == "1") {
            alertify.success("KPI Saved Successfully.");
            $('#create').text('Create');
            $('#datatab').DataTable().ajax.reload();
            ClearForm();
        }
        else if (response == "0") {
            alertify.error("Unable To Save KPIs.");
        }
        else if (response == "2") {
            alertify.error("Record Already Exists For This SO & Financial Year");
        }
        else {
            alertify.error(response);
        }
    }

    function OnFailure(response) {
        if (response.status == 422) {
            var errors = JSON.parse(response.responseText);
            alertify.error(errors.errors);
        }
        else {
            alertify.error(response);
        }
    }
</script>
