@model FOS.Web.UI.Controllers.SetupController.FinancialYearData

@{
    ViewBag.Title = "Financial Year";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li>
                <a href="#">Setup</a>
                <span class="divider">/</span>
            </li>
            <li>
                <a href="#">Manage Financial Year</a>
            </li>
        </ul>
    </div>
</div>

@using (Ajax.BeginForm("AddUpdateFinancialYear", "Setup", new AjaxOptions { OnSuccess = "OnSuccess", OnFailure = "OnFailure" }, new { @class = "form-horizontal" }))
{
    @Html.AntiForgeryToken()

    <div class="row-fluid">
        <div class="span12">
            <div class="widget green">
                <div class="widget-title">
                    <h4>Manage Financial Year</h4>
                    <span class="tools"></span>
                </div>
                <div class="widget-body">
                    <div class="control-group">
                        <label class="control-label">Financial Year *</label>
                        <div class="controls">
                            @Html.TextBoxFor(model => model.Year, new { @placeholder = "e.g. 2026-2027", @maxlength = "50" })
                            @Html.HiddenFor(model => model.ID)
                        </div>
                    </div>
                    <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                        <div class="form-actions" style="padding-left: 240px;">
                            <button type="submit" id="btnNew" class="btn btn-primary">
                                <i class="icon-ok icon-white" style="padding-right: 8px;"></i><span id="create">Create</span>
                            </button>
                            <button type="button" class="btn btn-small btn-info" id="btnRefresh"><i class="icon-ban-circle icon-white" style="padding-right: 8px;"></i>Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>View Detail</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">
                <div>
                    <div class="clearfix">
                        <div class="btn-group pull-right"></div>
                    </div>
                    <div class="space15"></div>
                    <table class="table table-striped table-hover table-bordered" id="datatab" style="width: 100%;">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th style="width: 10% !important">Sr #</th>
                                <th style="width: 45% !important">Financial Year</th>
                                <th style="width: 30% !important">Created On</th>
                                <th style="width: 15% !important">Actions</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function GenerateDetailGrid() {
        var oTable = $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("FinancialYearDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                'data': function (data) {
                    return data = JSON.stringify(data);
                }
            },
            "fnDrawCallback": function (osetting) {
                $(".edit").on("click", function () {
                    ClearForm();
                    $('#ID').val($(this).attr("data-id"));
                    $('#create').text('Update');
                    $("#Year").val($(this).attr("data-year"));
                    $('html, body').animate({
                        scrollTop: $("#main-content").offset().top
                    }, 500);
                    $("#Year").focus();
                });

                $(".delete").on("click", function () {
                    var id = $(this).attr("data-id");
                    alertify.confirm("Are You Sure You Want To Delete This Record ?  ", function (e) {
                        if (e) {
                            $.ajax({
                                type: "POST",
                                url: "@Url.Action("DeleteFinancialYear", "Setup")",
                                data: { ID: id },
                                success: function (data) {
                                    if (data == "0") {
                                        alertify.success('Record Deleted Successfully');
                                        $('#datatab').DataTable().ajax.reload();
                                    } else {
                                        alertify.error('Unable to delete record.');
                                    }
                                }
                            });
                        }
                    });
                });
            },
            "fnRowCallback": function (nRow, aData, iDisplayIndex) {
                $("td:first", nRow).html(iDisplayIndex + 1);
                return nRow;
            },
            "oLanguage": { "sSearch": "Search Financial Year : " },
            "sDom": 'lftipr',
            "processing": true,
            "deferRender": true,
            "bSelect": true,
            "columns": [
                { "data": "ID", "bVisible": false },
                { "data": "ID", "bSortable": false },
                { "data": "Year" },
                {
                    "data": "CreatedOn",
                    "mRender": function (data) {
                        if (!data) return "";
                        var d = new Date(parseInt(data.replace(/\D/g, '')));
                        if (isNaN(d.getTime())) return data;
                        var dd = ('0' + d.getDate()).slice(-2);
                        var mm = ('0' + (d.getMonth() + 1)).slice(-2);
                        return dd + '-' + mm + '-' + d.getFullYear();
                    }
                },
                {
                    "sClass": "center-align-td",
                    "mData": null,
                    "bSortable": false,
                    "mRender": function (data, type, row) {
                        return '<button class="btn btn-success edit" data-id=' + row.ID + ' data-year="' + row.Year + '"><i class=icon-pencil></i></button>&nbsp;<button class="btn btn-info delete" data-id=' + row.ID + '><i class=icon-trash></i></button>';
                    }
                }
            ],
            "order": [1, "desc"]
        });
    }

    $(document).ready(function () {
        $("#liSetup,#liFinancialYear").addClass("active");

        $("#btnRefresh").click(function () {
            ClearForm();
        });

        GenerateDetailGrid();
    });

    function ClearForm() {
        $('#Year').val('');
        $('#ID').val(0);
        $('#create').text('Create');
    }

    function OnSuccess(response) {
        if (response == "1") {
            alertify.success("Financial Year Saved Successfully");
            $('#create').text('Create');
            $('#datatab').DataTable().ajax.reload();
            ClearForm();
        }
        else if (response == "0") {
            alertify.error("Unable To Save Financial Year.");
        }
        else if (response == "2") {
            alertify.error("Financial Year Already Exists");
        }
        else {
            alertify.error(response);
        }
    }

    function OnFailure(response) {
        alertify.error("Request Failed");
    }
</script>
