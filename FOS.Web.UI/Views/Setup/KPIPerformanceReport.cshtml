@model FOS.Web.UI.Controllers.SetupController.KPIReportModel
@{
    ViewBag.Title = "KPI Performance Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li><a href="#">Setup</a><span class="divider">/</span></li>
            <li class="active">KPI Performance Report</li>
        </ul>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget-box">
            <div class="widget-title">
                <span class="icon"><i class="icon-th"></i></span>
                <h5>KPI Performance Report</h5>
            </div>
            <div class="widget-content nopadding">
                <div class="form-horizontal" style="padding:15px;">
                    <div class="control-group">
                        <label class="control-label">Financial Year</label>
                        <div class="controls">
                            <select id="FinancialYearID" name="FinancialYearID" class="span3">
                                <option value="">-- Select Financial Year --</option>
                                @foreach (var fy in Model.FinancialYears)
                                {
                                    <option value="@fy.ID">@fy.Year</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="control-group">
                        <label class="control-label">Quarter</label>
                        <div class="controls">
                            <select id="Quarter" name="Quarter" class="span3">
                                <option value="">-- Select Quarter --</option>
                            </select>
                        </div>
                    </div>
                    <div class="control-group">
                        <label class="control-label">Regional Head</label>
                        <div class="controls">
                            <select id="RegionalHeadID" name="RegionalHeadID" class="span3">
                                <option value="0">-- All --</option>
                                @foreach (var rh in Model.RegionalHeads)
                                {
                                    <option value="@rh.ID">@rh.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="control-group">
                        <div class="controls">
                            <button type="button" id="btnExport" class="btn btn-primary">
                                <i class="icon-download"></i> Export to Excel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    $("#FinancialYearID").change(function () {
        var fyid = $(this).val();
        $('#Quarter').empty().append('<option value="">-- Select Quarter --</option>');
        if (fyid && fyid !== '') {
            $.get('@Url.Action("GetQuartersByFinancialYear", "Setup")', { financialYearID: fyid }, function (data) {
                $.each(data, function (i, q) {
                    $('#Quarter').append('<option value="' + q.Name + '">' + q.Name + '</option>');
                });
            });
        }
    });

    $("#btnExport").click(function () {
        var fyid = $('#FinancialYearID').val();
        var quarter = $('#Quarter').val();
        var rhid = $('#RegionalHeadID').val() || 0;

        if (!fyid || fyid === '') {
            alertify.alert('Please select a Financial Year.');
            return;
        }
        if (!quarter || quarter === '') {
            alertify.alert('Please select a Quarter.');
            return;
        }

        window.location.href = '@Url.Action("ExportKPIPerformanceReport", "Setup")?FinancialYearID=' + fyid + '&Quarter=' + encodeURIComponent(quarter) + '&RegionalHeadID=' + rhid;
    });
</script>
