@model FOS.Web.UI.Controllers.SetupController.AreaCoverageData
@{
    ViewBag.Title = "Area Coverage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-fluid">
    <div class="span12">
        <h3 class="page-title"></h3>
        <ul class="breadcrumb">
            <li><a href="#">Setup</a><span class="divider">/</span></li>
            <li><a href="#">Area Coverage</a></li>
        </ul>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title">
                <h4>Manage Area Coverage</h4>
                <span class="tools"></span>
            </div>
            <div class="widget-body">

                <div class="control-group">
                    <label class="control-label">Regional Head *</label>
                    <div class="controls">
                        <select id="RegionalHeadID" name="RegionalHeadID">
                            <option value="">-- Select Regional Head --</option>
                            @foreach (var rh in Model.RegionalHeads ?? new List<FOS.Web.UI.Controllers.SetupController.DropDownItem>())
                            {
                                <option value="@rh.ID">@rh.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">SO Name *</label>
                    <div class="controls">
                        <select id="SOID" name="SOID">
                            <option value="">-- Select SO --</option>
                        </select>
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Region *</label>
                    <div class="controls">
                        <select id="RegionID" name="RegionID">
                            <option value="">-- Select Region --</option>
                            @foreach (var r in Model.Regions ?? new List<FOS.Web.UI.Controllers.SetupController.DropDownItem>())
                            {
                                <option value="@r.ID">@r.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="control-group">
                    <label class="control-label">Area List *</label>
                    <div class="controls">
                        <div id="areaListBox" style="width:60%;max-height:240px;overflow-y:auto;border:1px solid #ddd;border-radius:4px;padding:8px;background:#fafafa">
                            <div style="color:#888">Select a Region to load areas</div>
                        </div>
                        <div style="margin-top:6px">
                            <label style="display:inline-block;font-weight:normal;cursor:pointer">
                                <input type="checkbox" id="chkSelectAllAreas" /> Select All
                            </label>
                        </div>
                    </div>
                </div>

                <div class="control-group" style="border-top: 1px solid #e5e5e5;">
                    <div class="form-actions" style="padding-left:238px">
                        <button type="button" id="btnSave" class="btn btn-primary">
                            <i class="icon-ok icon-white" style="padding-right:8px"></i>Save
                        </button>
                        <button type="button" id="btnReset" class="btn btn-info">
                            <i class="icon-ban-circle icon-white" style="padding-right:8px"></i>Reset
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="widget green">
            <div class="widget-title"><h4>View Detail</h4></div>
            <div class="widget-body">
                <table class="table table-striped table-hover table-bordered" id="datatab" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th style="width:6%">Sr #</th>
                            <th>Regional Head</th>
                            <th>SO Name</th>
                            <th>Region</th>
                            <th>Area</th>
                            <th>Created On</th>
                            <th style="width:8%">Action</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function LoadSOs() {
        var rhID = $('#RegionalHeadID').val();
        var $so = $('#SOID');
        $so.empty().append('<option value="">-- Select SO --</option>');
        if (!rhID) return;

        $.getJSON('@Url.Action("GetSOByRegionalHeadID", "Setup")', { RegionalHeadID: rhID }, function (data) {
            $.each(data || [], function (i, s) {
                $so.append('<option value="' + s.ID + '">' + s.Name + '</option>');
            });
        });
    }

    function LoadAreas() {
        var rID = $('#RegionID').val();
        var $box = $('#areaListBox');
        $box.empty();
        $('#chkSelectAllAreas').prop('checked', false);
        if (!rID) {
            $box.html('<div style="color:#888">Select a Region to load areas</div>');
            return;
        }

        $box.html('<div style="color:#888">Loading...</div>');
        $.getJSON('@Url.Action("GetAreasByRegionID", "Setup")', { RegionID: rID }, function (data) {
            $box.empty();
            if (!data || data.length == 0) {
                $box.html('<div style="color:#888">No areas in this region</div>');
                return;
            }
            $.each(data, function (i, a) {
                var lbl = $('<label></label>')
                    .css({ display: 'inline-block', width: '32%', fontWeight: 'normal', cursor: 'pointer', padding: '3px 6px', margin: '2px' });
                lbl.append('<input type="checkbox" class="area-chk" value="' + a.ID + '" style="margin-right:6px" /> ' + a.Name);
                $box.append(lbl);
            });
        });
    }

    function GetSelectedAreaIDs() {
        return $('#areaListBox .area-chk:checked').map(function () { return parseInt(this.value); }).get();
    }

    function SaveAreaCoverage() {
        var rh = $('#RegionalHeadID').val();
        var so = $('#SOID').val();
        var r = $('#RegionID').val();
        var areas = GetSelectedAreaIDs();

        if (!rh) { alertify.error("Please select Regional Head"); return; }
        if (!so) { alertify.error("Please select SO"); return; }
        if (!r) { alertify.error("Please select Region"); return; }
        if (areas.length == 0) { alertify.error("Please select at least one Area"); return; }

        var payload = {
            RegionalHeadID: parseInt(rh),
            SOID: parseInt(so),
            RegionID: parseInt(r),
            AreaIDs: areas
        };

        $.ajax({
            url: '@Url.Action("SaveAreaCoverage", "Setup")',
            type: 'POST',
            contentType: 'application/json; charset=utf-8',
            data: JSON.stringify(payload),
            success: function (resp) {
                if (resp == "1") {
                    alertify.success("Area Coverage saved successfully.");
                    $('#datatab').DataTable().ajax.reload();
                    ClearForm();
                } else if (resp == "0") {
                    alertify.error("Unable to save. Check all required fields.");
                } else {
                    alertify.error(resp);
                }
            },
            error: function () { alertify.error("Save failed."); }
        });
    }

    function GenerateDetailGrid() {
        if ($.fn.DataTable.isDataTable('#datatab')) {
            $('#datatab').DataTable().destroy();
            $('#datatab tbody').empty();
        }
        $('#datatab').DataTable({
            "aLengthMenu": [[10, 25, 50, 75, 100], [10, 25, 50, 75, 100]],
            "iDisplayLength": 10,
            "paging": true,
            "pagingType": "full_numbers",
            "serverSide": true,
            "bRetrieve": true,
            "bDestroy": true,
            "autoWidth": true,
            "ajax": {
                "type": "POST",
                "url": '@Url.Action("AreaCoverageDataHandler", "Setup")',
                "contentType": 'application/json; charset=utf-8',
                "dataType": "json",
                "data": function (d) {
                    d.RegionalHeadID = $('#RegionalHeadID').val() || 0;
                    d.SOID = $('#SOID').val() || 0;
                    d.RegionID = $('#RegionID').val() || 0;
                    return JSON.stringify(d);
                }
            },
            "columns": [
                { "data": "ID", "bVisible": false },
                {
                    "data": null, "bSortable": false,
                    "render": function (d, t, r, m) { return m.row + m.settings._iDisplayStart + 1; }
                },
                { "data": "RegionalHeadName" },
                { "data": "SOName" },
                { "data": "RegionName" },
                { "data": "AreaName" },
                {
                    "data": "CreatedOn",
                    "render": function (data) {
                        if (!data) return "";
                        var d = new Date(parseInt(data.replace(/\D/g, '')));
                        if (isNaN(d.getTime())) return data;
                        var dd = ('0' + d.getDate()).slice(-2);
                        var mm = ('0' + (d.getMonth() + 1)).slice(-2);
                        return dd + '-' + mm + '-' + d.getFullYear();
                    }
                },
                {
                    "data": "ID", "bSortable": false,
                    "render": function (id) {
                        return '<button type="button" class="btn btn-danger btn-mini btn-delete-ac" data-id="' + id + '"><i class="icon-trash icon-white"></i> Delete</button>';
                    }
                }
            ],
            "language": { "sSearch": "Search: " },
            "sDom": 'lftipr',
            "order": [[1, "asc"]]
        });
    }

    function ClearForm() {
        $('#RegionalHeadID').val('');
        $('#SOID').empty().append('<option value="">-- Select SO --</option>');
        $('#RegionID').val('');
        $('#areaListBox').html('<div style="color:#888">Select a Region to load areas</div>');
        $('#chkSelectAllAreas').prop('checked', false);
    }

    function DeleteAC(id) {
        alertify.confirm("Soft-delete this Area Coverage row?", function () {
            $.post('@Url.Action("DeleteAreaCoverage", "Setup")', { ID: id }, function (resp) {
                if (resp == "1") {
                    alertify.success("Deleted.");
                    $('#datatab').DataTable().ajax.reload();
                } else {
                    alertify.error("Delete failed.");
                }
            }).fail(function () { alertify.error("Delete failed."); });
        });
    }

    $(document).ready(function () {
        $("#liSetup,#liAreaCoverage").addClass("active");

        $('#RegionalHeadID').change(function () {
            LoadSOs();
            GenerateDetailGrid();
        });
        $('#SOID, #RegionID').change(function () {
            GenerateDetailGrid();
        });
        $('#RegionID').change(function () {
            LoadAreas();
        });
        $('#btnSave').click(SaveAreaCoverage);
        $('#btnReset').click(ClearForm);

        $('#chkSelectAllAreas').change(function () {
            $('#areaListBox .area-chk').prop('checked', this.checked);
        });

        $(document).on('click', '.btn-delete-ac', function () {
            var id = $(this).data('id');
            DeleteAC(id);
        });

        GenerateDetailGrid();
    });
</script>
